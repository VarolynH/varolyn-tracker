# ══════════════════════════════════════════════════════
#  Varolyn Healthcare — Environment Variables
# ══════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  IMPORTANT: Never commit .env to version control!
# ══════════════════════════════════════════════════════

# ── Server ──
PORT=8080
NODE_ENV=production
LOG_LEVEL=info

# ── PostgreSQL ──
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Security (REQUIRED — generate your own!) ──
# JWT secret for admin authentication (any random string, 32+ chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_with_crypto_randomBytes

# AES-256 encryption key for PII at rest (exactly 64 hex chars = 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_generate_64_hex_chars_for_aes256

# ── Admin Account (seeded on first start) ──
ADMIN_EMAIL=admin@varolynhealthcare.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ── CORS (comma-separated origins, leave empty for permissive) ──
# Example: https://track.varolynhealthcare.com,https://admin.varolynhealthcare.com
ALLOWED_ORIGINS=

# ── Zoho CRM Integration (optional) ──
# Webhook URL from Zoho Flow / Zoho CRM
# Events: session_started, session_stopped
# Payload includes: staffName, staffPhone, staffEmail, designation, trackingToken
ZOHO_CRM_WEBHOOK_URL=
